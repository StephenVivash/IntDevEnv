<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ManagedConsole\ManagedConsole.vcxproj" />
  </ItemGroup>

  <Target Name="CopyNativeDependencies" AfterTargets="Build">
    <ItemGroup>
      <NativeDependency Include="..\$(PlatformTarget)\$(Configuration)\MonitorConsole.dll" Condition="Exists('..\$(PlatformTarget)\$(Configuration)\MonitorConsole.dll')" />
      <NativeDependency Include="..\MonitorConsole\$(PlatformTarget)\$(Configuration)\MonitorConsole.dll" Condition="Exists('..\MonitorConsole\$(PlatformTarget)\$(Configuration)\MonitorConsole.dll')" />
    </ItemGroup>
    <Copy SourceFiles="@(NativeDependency)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
